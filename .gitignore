*.pyc
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.ipynb_checkpoints/
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/

# ==========================================
# Rust Core Engine
# ==========================================
target/
**/target/
Cargo.lock

# ==========================================
# Frontend Node / Next.js
# ==========================================
node_modules/
.next/
out/
coverage/

# ==========================================
# Pipeline Auto-Generated Artifacts & Caches
# ==========================================
# Extractor auto-generated state
/Extractor/population.json
/Extractor/history.csv
/Extractor/*.tmp

# RAM-derived caches or embeddings
/RAM/**/*.emb
/RAM/**/*.cache

# Logs / Theory / Experiments Temp
/Logs/**/*.tmp
/Theory/**/*.tmp
experiments/**/results/
experiments/**/logs/
results/
logs/

# ==========================================
# Ledger Databases & Runtime Swaps
# ==========================================
# Restricts JSON/MD ignoring to the outputs workspace to protect configuration source files
/outputs/**/*.json
/outputs/**/*.md
outputs/
*.tmp
*.bak
*.log

# Prevents Git from tracking live data engine mutations inside the crate layout
/engine/engine-core/ledger/*.json
/engine/engine-core/ledger/*.jsonl
/engine/engine-core/ledger/*.tmp
/engine/engine-core/ledger/*.lock

# ==========================================
# Credentials & Environment Secrets
# ==========================================
.env
.env.local
.env.*.local

# ==========================================
# System, OS, & Editor Workspaces
# ==========================================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
.cache/